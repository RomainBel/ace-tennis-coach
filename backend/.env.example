# Copie ce fichier vers .env et remplis les valeurs.
# Ne commite jamais le fichier .env.

OPENAI_API_KEY=
# Modèle chat (voir OpenAI Models)
OPENAI_MODEL=gpt-4.1-mini

# Optionnel — transcription vocale dans le chat
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Optionnel — utilisé pour certains liens / CORS si besoin en prod
# PUBLIC_APP_URL=http://localhost:3000
